{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "ThisIsASecretKeyForTsqrIdentity_MustBeAtLeast32CharactersLong!",
    "Issuer": "tsqr-identity",
    "Audience": "tsqr-services",
    "AccessTokenExpirationMinutes": 15
  },
  "ReverseProxy": {
    "Routes": {
      "identity-auth-register": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/auth/register" },
        "Methods": ["POST"]
      },
      "identity-auth-login": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/auth/login" },
        "Methods": ["POST"]
      },
      "identity-auth-refresh": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/auth/refresh" },
        "Methods": ["POST"]
      },
      "identity-auth": {
        "ClusterId": "identity",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "identity-users": {
        "ClusterId": "identity",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      "identity-roles": {
        "ClusterId": "identity",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/api/roles/{**catch-all}" }
      },
      "tool-api": {
        "ClusterId": "tool-lib",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/api/{**catch-all}" }
      },
      "spa": {
        "ClusterId": "ui",
        "Match": { "Path": "/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": { "dest": { "Address": "http://localhost:5068" } }
      },
      "tool-lib": {
        "Destinations": { "dest": { "Address": "http://localhost:5079" } }
      },
      "ui": {
        "Destinations": { "dest": { "Address": "http://localhost:3000" } }
      }
    }
  }
}
