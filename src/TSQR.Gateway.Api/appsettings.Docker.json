{
  "Services": {
    "Autheo": "http://autheo:8080",
    "ToolLib": "http://tool-lib:8080",
    "Support": "http://support:8080",
    "Identity": "http://identity:8080",
    "SoupKitchen": "http://soup-kitchen:8080",
    "Communities": "http://communities:8080"
  },
  "ReverseProxy": {
    "Routes": {
      "autheo-auth-register": {
        "ClusterId": "autheo",
        "Match": { "Path": "/api/auth/register", "Methods": ["POST"] }
      },
      "autheo-auth-login": {
        "ClusterId": "autheo",
        "Match": { "Path": "/api/auth/login", "Methods": ["POST"] }
      },
      "autheo-auth-refresh": {
        "ClusterId": "autheo",
        "Match": { "Path": "/api/auth/refresh", "Methods": ["POST"] }
      },
      "autheo-auth-health": {
        "ClusterId": "autheo",
        "Match": { "Path": "/api/auth/health", "Methods": ["GET"] }
      },
      "autheo-auth": {
        "ClusterId": "autheo",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "support-public": {
        "ClusterId": "support",
        "Match": { "Path": "/api/apps", "Methods": ["GET"] }
      },
      "support-uptime": {
        "ClusterId": "support",
        "Match": { "Path": "/api/uptime/{**catch-all}", "Methods": ["GET"] }
      },
      "support-team": {
        "ClusterId": "support",
        "Match": { "Path": "/api/team", "Methods": ["GET"] }
      },
      "support-content": {
        "ClusterId": "support",
        "Match": { "Path": "/api/content/{**catch-all}", "Methods": ["GET"] }
      },
      "support-tickets-read": {
        "ClusterId": "support",
        "Match": { "Path": "/api/tickets", "Methods": ["GET"] }
      },
      "support-tickets-get": {
        "ClusterId": "support",
        "Match": { "Path": "/api/tickets/{id}", "Methods": ["GET"] }
      },
      "support-tickets-submit": {
        "ClusterId": "support",
        "Match": { "Path": "/api/tickets", "Methods": ["POST"] }
      },
      "support-contact": {
        "ClusterId": "support",
        "Match": { "Path": "/api/contact", "Methods": ["POST"] }
      },
      "support-health": {
        "ClusterId": "support",
        "Match": { "Path": "/api/support/health", "Methods": ["GET"] }
      },
      "support-admin": {
        "ClusterId": "support",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/api/tickets/{**catch-all}", "Methods": ["PATCH"] }
      },
      "identity-profile-health": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/health", "Methods": ["GET"] }
      },
      "identity-profile": {
        "ClusterId": "identity",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/api/profile/{**catch-all}" }
      },
      "identity-profile-avatar": {
        "ClusterId": "identity",
        "AuthorizationPolicy": "Anonymous",
        "Match": { "Path": "/api/profile/avatar/{userId}", "Methods": ["GET"] }
      },
      "identity-users": {
        "ClusterId": "identity",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      "identity-roles": {
        "ClusterId": "identity",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/api/roles/{**catch-all}" }
      },
      "tool-api": {
        "ClusterId": "tool-lib",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/api/{**catch-all}" }
      },
      "tool-public-dashboard": {
        "ClusterId": "tool-lib",
        "Match": { "Path": "/api/dashboard/stats", "Methods": ["GET"] }
      },
      "tool-public-manufacturers": {
        "ClusterId": "tool-lib",
        "Match": { "Path": "/api/manufacturers", "Methods": ["GET"] }
      },
      "tool-public-tools-list": {
        "ClusterId": "tool-lib",
        "Match": { "Path": "/api/tools", "Methods": ["GET"] }
      },
      "tool-public-tools-detail": {
        "ClusterId": "tool-lib",
        "Match": { "Path": "/api/tools/{id}", "Methods": ["GET"] }
      },
      "tool-public-tools-stats": {
        "ClusterId": "tool-lib",
        "Match": { "Path": "/api/tools/stats", "Methods": ["GET"] }
      },
      "soup-kitchen-public-dashboard": {
        "ClusterId": "soup-kitchen",
        "Match": { "Path": "/api/soup-kitchen/dashboard/stats", "Methods": ["GET"] }
      },
      "soup-kitchen-public-events-list": {
        "ClusterId": "soup-kitchen",
        "Match": { "Path": "/api/soup-kitchen/events", "Methods": ["GET"] }
      },
      "soup-kitchen-public-events-detail": {
        "ClusterId": "soup-kitchen",
        "Match": { "Path": "/api/soup-kitchen/events/{id}", "Methods": ["GET"] }
      },
      "soup-kitchen-public-meals": {
        "ClusterId": "soup-kitchen",
        "Match": { "Path": "/api/soup-kitchen/meals", "Methods": ["GET"] }
      },
      "soup-kitchen-public-volunteers": {
        "ClusterId": "soup-kitchen",
        "Match": { "Path": "/api/soup-kitchen/volunteers", "Methods": ["GET"] }
      },
      "soup-kitchen-public-donations": {
        "ClusterId": "soup-kitchen",
        "Match": { "Path": "/api/soup-kitchen/donations", "Methods": ["GET"] }
      },
      "soup-kitchen-public-guests": {
        "ClusterId": "soup-kitchen",
        "Match": { "Path": "/api/soup-kitchen/guests", "Methods": ["GET"] }
      },
      "soup-kitchen-api": {
        "ClusterId": "soup-kitchen",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/api/soup-kitchen/{**catch-all}" }
      },
      "communities-public-countries": {
        "ClusterId": "communities",
        "Match": { "Path": "/api/communities/countries", "Methods": ["GET"] }
      },
      "communities-public-cities": {
        "ClusterId": "communities",
        "Match": { "Path": "/api/communities/cities", "Methods": ["GET"] }
      },
      "communities-public-neighbourhoods": {
        "ClusterId": "communities",
        "Match": { "Path": "/api/communities/neighbourhoods", "Methods": ["GET"] }
      },
      "communities-public-dashboard": {
        "ClusterId": "communities",
        "Match": { "Path": "/api/communities/dashboard/stats", "Methods": ["GET"] }
      },
      "communities-public-list": {
        "ClusterId": "communities",
        "Match": { "Path": "/api/communities", "Methods": ["GET"] }
      },
      "communities-public-detail": {
        "ClusterId": "communities",
        "Match": { "Path": "/api/communities/{id}", "Methods": ["GET"] }
      },
      "communities-public-quick-register": {
        "ClusterId": "communities",
        "Match": { "Path": "/api/communities/quick-register", "Methods": ["POST"] }
      },
      "communities-api": {
        "ClusterId": "communities",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/api/communities/{**catch-all}" }
      },
      "spa": {
        "ClusterId": "ui",
        "Match": { "Path": "/{**catch-all}" }
      }
    },
    "Clusters": {
      "autheo": {
        "Destinations": { "dest": { "Address": "http://autheo:8080" } }
      },
      "tool-lib": {
        "Destinations": { "dest": { "Address": "http://tool-lib:8080" } }
      },
      "support": {
        "Destinations": { "dest": { "Address": "http://support:8080" } }
      },
      "identity": {
        "Destinations": { "dest": { "Address": "http://identity:8080" } }
      },
      "ui": {
        "Destinations": { "dest": { "Address": "http://ui:3000" } }
      },
      "soup-kitchen": {
        "Destinations": { "dest": { "Address": "http://soup-kitchen:8080" } }
      },
      "communities": {
        "Destinations": { "dest": { "Address": "http://communities:8080" } }
      }
    }
  }
}